{
  "version": 2,
  "buildCommand": "cd frontend-react && npm install && npm run build",
  "outputDirectory": "frontend/static/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
