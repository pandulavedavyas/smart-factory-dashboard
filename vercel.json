{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/static/(.*)", "dest": "/frontend/static/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*\\.html)", "dest": "/api/index.py" },
    { "src": "/(auth|dashboard|login|workers|machinery|production|materials|analytics|predictions|reports|settings|datasets|logout)(.*)?", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
