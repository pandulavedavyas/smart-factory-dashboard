# Firebase Web config (optional).
# When ALL of these are set, the app uses real Firebase Auth
# (email/password + Google SSO) and mirrors roles to Firestore.
# Leave them blank to run with the backend auth fallback (dev).
#
# After setting, run:  npm install firebase

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
